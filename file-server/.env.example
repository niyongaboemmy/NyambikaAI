# File Server Configuration
PORT=3004
NODE_ENV=development

# Base URL exposed to clients (used to build file URLs returned in responses)
FILE_SERVER_BASE_URL=http://localhost:3004

# Absolute path to uploads directory (defaults to ./uploads if unset)
# UPLOADS_DIR=/var/www/nyambika/uploads

# Optional API key for upload/delete endpoints (leave blank to disable auth in dev)
FILE_SERVER_API_KEY=your_secret_api_key_here

# Allowed CORS origins (comma-separated list or * to allow all)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003,https://nyambika.com
